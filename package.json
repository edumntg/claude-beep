{
  "name": "claude-beep",
  "version": "1.0.0",
  "description": "Two-way notifications for Claude Code via Telegram, Discord, and Slack",
  "type": "module",
  "bin": {
    "claude-beep": "./dist/cli.js"
  },
  "files": [
    "dist",
    "scripts",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node scripts/fix-pty-perms.js",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@slack/socket-mode": "^2.0.7",
    "@slack/web-api": "^7.17.0",
    "commander": "^12.1.0",
    "discord.js": "^14.26.4",
    "node-pty": "^1.1.0",
    "ws": "^8.21.0",
    "yaml": "^2.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "notifications",
    "telegram",
    "discord",
    "slack",
    "agent",
    "cli",
    "hooks"
  ],
  "author": "Eduardo Montilva",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edumntg/claude-beep.git"
  },
  "bugs": {
    "url": "https://github.com/edumntg/claude-beep/issues"
  },
  "homepage": "https://github.com/edumntg/claude-beep#readme",
  "publishConfig": {
    "access": "public"
  }
}
